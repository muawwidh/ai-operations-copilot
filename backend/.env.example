APP_NAME=AI Operations Copilot
APP_ENV=development
APP_DEBUG=true

API_PREFIX=/api

DATABASE_URL=postgresql+psycopg2://copilot_user:copilot_password@localhost:5432/ai_operations_copilot

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
CHROMA_COLLECTION_NAME=operations_documents

LOG_LEVEL=INFO